<!DOCTYPE html>
<html>

<head>
  <title>Catálogo de Filmes</title>
  <style>

    body{
      font-family: Arial, sans-serif;
      background:#f4f4f4;
      padding:40px;
    }

    h1{
      text-align:center;
    }

    table{
      width:80%;
      margin:auto;
      border-collapse: collapse;
      background:white;
    }

    th, td{
      padding:12px;
      border:1px solid #ddd;
      text-align:left;
    }

    th{
      background:#333;
      color:white;
    }

  </style>
</head>

<body>

<h1>Lista de Filmes</h1>

<table>

<thead>
<tr>
<th>ID</th>
<th>Título</th>
<th>Ano</th>
<th>IMDB</th>
</tr>
</thead>

<tbody>

<% filmes.forEach(filme => { %>

<tr>
<td><%= filme.id %></td>
<td><%= filme.title %></td>
<td><%= filme.year %></td>
<td><%= filme.imdb_id %></td>
</tr>

<% }) %>

</tbody>

</table>

</body>

</html>